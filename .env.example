# FPM consent plane — local config. Copy to `.env` and fill in.
# `.env` is gitignored; real environment variables override these.
# Loaded by config.py via python-dotenv.

# ── Google sign-in (the dashboard's standalone login) ────────────────────────
# Create an OAuth 2.0 "Web application" client in Google Cloud Console:
#   APIs & Services → Credentials → Create OAuth client ID → Web application
# Authorized redirect URI (must match FPM_OAUTH_REDIRECT_URI below, exactly):
#   http://localhost:3002/auth/callback
# Then add your Google account under the OAuth consent screen → Test users.
FPM_GOOGLE_CLIENT_ID=
FPM_GOOGLE_CLIENT_SECRET=
FPM_OAUTH_REDIRECT_URI=http://localhost:3002/auth/callback

# ── Session signing ──────────────────────────────────────────────────────────
# HMAC key for the dashboard session cookie. Set any long random string in prod
# (unset → a random per-process key, which logs everyone out on restart).
FPM_SESSION_SECRET=change-me-to-a-long-random-string

# ── Local-demo convenience ───────────────────────────────────────────────────
# Google-free login at /auth/dev-login?email=… — NEVER enable in production.
FPM_DEV_LOGIN=1

# ── Storage ──────────────────────────────────────────────────────────────────
FPM_DATA_DIR=./data
# AES key for the encrypted voiceprint store (unset → a key file under FPM_DATA_DIR).
# FPM_DB_KEY=

# ── Machine-to-machine API tokens (Recato / Conclave callers) ────────────────
# JSON: {token: {name, endpoints[], workspaces?[]}}. Needed for /v1/diarize etc.
# FPM_AUTH_TOKENS={"conclave-tok":{"name":"conclave","endpoints":["diarize","identify","voiceprints","knowledge"]}}

# ── Diarizer engine ──────────────────────────────────────────────────────────
# diart (default) requires the .venv-diart venv + cached pyannote models.
# FPM_DIARIZER=diart
