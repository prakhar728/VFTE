# FPM backend — sealed env for Phala deploy. Copy to `.env.sealed`, fill in, and
# pass with `phala deploy -e deploy/backend/.env.sealed` (values are encrypted to
# the CVM). `.env.sealed` is gitignored. Do NOT set FPM_DB_KEY or FPM_DEV_LOGIN.

IMAGE=prakharojha/fpm-backend:v1

# end-user Google sign-in (register the redirect URI in Google Console)
FPM_GOOGLE_CLIENT_ID=
FPM_GOOGLE_CLIENT_SECRET=
FPM_OAUTH_REDIRECT_URI=https://<frontend-or-backend-host>/auth/callback
# long random string — session cookie signing (unset = everyone logged out on restart)
FPM_SESSION_SECRET=

# M2M callers (Recato / Conclave). JSON: {token:{name,endpoints[],workspaces?[]}}
FPM_AUTH_TOKENS={"conclave-tok":{"name":"conclave","endpoints":["diarize","identify","voiceprints","knowledge"]}}

# the separate diarize CVM
FPM_DIARIZER_URL=https://<diarize-cvm-host>
FPM_DIARIZE_TOKEN=
